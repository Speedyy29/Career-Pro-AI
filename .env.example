# ============================================================
# CareerBoost AI — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# You need exactly 6 values. Instructions are in README.md.
# ============================================================

# --------------------------------------------------
# 1. DATABASE_URL (Neon free PostgreSQL)
# --------------------------------------------------
# Get this from: https://console.neon.tech
# After creating a project, copy the connection string.
# It looks like: postgresql://username:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:password@host:port/dbname?sslmode=require"

# --------------------------------------------------
# 2. AUTH_SECRET (any random 32+ character string)
# --------------------------------------------------
# Generate one with this terminal command:
#   npx auth secret
# Or just use any random string like: "my-super-secret-key-change-me-12345678"
AUTH_SECRET="generate-a-random-secret-at-least-32-characters"

# --------------------------------------------------
# 3. NEXTAUTH_URL (your app's URL)
# --------------------------------------------------
# For LOCAL development, use:
NEXTAUTH_URL="http://localhost:3000"
# For VERCEL deployment, use your Vercel URL:
# NEXTAUTH_URL="https://your-project-name.vercel.app"

# --------------------------------------------------
# 4. GOOGLE_GENERATIVE_AI_API_KEY (Gemini AI)
# --------------------------------------------------
# Get a FREE key from: https://aistudio.google.com/apikey
# Click "Create API Key" and copy it here.
GOOGLE_GENERATIVE_AI_API_KEY="your-gemini-api-key"

# --------------------------------------------------
# 5 & 6. GOOGLE OAUTH (for "Sign in with Google" button)
# --------------------------------------------------
# Get these from: https://console.cloud.google.com/apis/credentials
# Steps are in README.md section "Google OAuth Setup".
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"
